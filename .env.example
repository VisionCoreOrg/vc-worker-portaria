# ==========================================
# Configurações do MinIO (Storage)
# ==========================================
MINIO_ROOT_USER=visioncore_admin
MINIO_ROOT_PASSWORD=sua_senha_minio_aqui
MINIO_ENDPOINT=http://visioncore-minio:9000
MINIO_BUCKET_NAME=plate-bucket

# ==========================================
# Configurações da API Core (FastAPI)
# ==========================================
API_URL=http://api_core:8000/api/vagas/registro
CAMERA_ID=portaria_principal

# ==========================================
# Configurações do Redis (parking-infra)
# ==========================================
REDIS_HOST=parking_redis
REDIS_PORT=6379
REDIS_PASSWORD=sua_senha_redis_aqui
REDIS_QUEUE=camera:portaria:queue

# ==========================================
# Configurações de GPU (opcional)
# ==========================================
# Controla qual hardware usar para inferência de IA.
# none   → CPU puro (padrão — funciona em qualquer máquina)
# nvidia → GPU NVIDIA via CUDA (requer build com GPU_BUILD=nvidia)
#
# Para rodar com GPU NVIDIA:
#   docker-compose -f docker-compose.yml -f docker-compose.gpu.yml up --build
GPU_PROVIDER=none